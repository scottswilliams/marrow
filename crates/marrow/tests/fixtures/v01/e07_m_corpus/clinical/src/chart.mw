store ^charts[mrn: int]: Chart

pub fn recordName(mrn: int, name: string) {
    transaction {
        ^charts[mrn].name = name
    }
}

pub fn nameOf(mrn: int): string? {
    return ^charts[mrn].name
}

pub fn setWeight(mrn: int, grams: int) {
    transaction {
        place chart = ^charts[mrn]
        if exists(chart) {
            chart.weightG = grams
        }
    }
}

pub fn setHeight(mrn: int, mm: int) {
    transaction {
        place chart = ^charts[mrn]
        if exists(chart) {
            chart.heightMm = mm
        }
    }
}

// A group-leaf write addresses the inline `^root[key].group.leaf` path: a group
// leaf is not reachable through a named `place` binding, so the three vitals are
// each written at their full inline path under one presence guard.
pub fn setVital(mrn: int, systolic: int, diastolic: int, heartRate: int) {
    transaction {
        if exists(^charts[mrn]) {
            ^charts[mrn].vitals.systolic = systolic
            ^charts[mrn].vitals.diastolic = diastolic
            ^charts[mrn].vitals.heartRate = heartRate
        }
    }
}

pub fn systolicOf(mrn: int): int? {
    return ^charts[mrn].vitals.systolic
}

// Presence prelude: several sparse preconditions, each a diverging guard, so the
// body runs only once every measurement it needs is present.
pub fn bpSummary(mrn: int): Result<string, string> {
    if not exists(^charts[mrn]) { return err("unknown chart") }
    const name = ^charts[mrn].name else return err("chart has no name")
    const sys = ^charts[mrn].vitals.systolic else return err($"{name} has no systolic")
    const dia = ^charts[mrn].vitals.diastolic else return err($"{name} has no diastolic")
    return ok($"{name} {sys}/{dia}")
}

// The int-floor arithmetic slice. Body-mass index is weight(kg) / height(m)^2 =
// a fractional quantity. With an int-only floor it is carried at a fixed scale of
// x10: weight is stored in grams and height in millimetres, and the ratio is
// scaled by 10 with an explicit rounding half-add before the truncating divide.
// A decimal type would remove the gram/millimetre unit choice, the *10 scale, and
// the half-add rounding; this records where the int floor is felt.
pub fn bmiTimesTen(mrn: int): Result<int, string> {
    const grams = ^charts[mrn].weightG else return err("no weight")
    const mm = ^charts[mrn].heightMm else return err("no height")
    if mm <= 0 { return err("nonpositive height") }
    const areaMm2 = checked mm * mm
        on out_of_range return err("height overflow")
    if areaMm2 <= 0 { return err("height overflow") }
    // weight(kg)/height(m)^2 at the fixed x10 scale. With weight in grams and height
    // in millimetres this simplifies to grams * 10000 / areaMm2, and the half-add
    // (+ areaMm2/2) rounds the truncating integer divide to nearest.
    const scaled = checked grams * 10000
        on out_of_range return err("weight overflow")
    const half = areaMm2 / 2
    const numerator = checked scaled + half
        on out_of_range return err("scale overflow")
    const bmi10 = checked numerator / areaMm2
        on out_of_range {
            return err("bmi overflow")
        } on zero_divisor return err("zero area")
    return ok(bmi10)
}

// Three-state sparse read: the field is absent (never recorded), present `none`
// (recorded as unmeasurable), or present `some(v)` (a measured value).
pub fn glucoseState(mrn: int): string {
    if const stored = ^charts[mrn].glucoseReading {
        match stored {
            some(v) => return "measured"
            none => return "unmeasurable"
        }
    }
    return "unrecorded"
}

pub fn recordGlucose(mrn: int, value: int) {
    transaction {
        place chart = ^charts[mrn]
        if exists(chart) {
            chart.glucoseReading = some(value)
        }
    }
}

pub fn recordGlucoseUnmeasurable(mrn: int) {
    transaction {
        place chart = ^charts[mrn]
        if exists(chart) {
            chart.glucoseReading = none
        }
    }
}

pub fn addObservation(mrn: int, seq: int, code: string, at: instant, value: int) {
    transaction {
        ^charts[mrn].observations[seq] = Chart.observations(recordedAt: at, code: code, value: value)
    }
}

// Presence-in-a-loop: sum the present observation values under one chart, counting
// each present entry's sparse `value` (an absent value reads as 0), with a bounded traversal.
pub fn observationTotal(mrn: int): int {
    var total = 0
    place chart = ^charts[mrn]
    for seq, ob in chart.observations at most 1000 {
        if const got = ob {
            total += got.value ?? 0
        }
    } on more return -1
    return total
}

pub fn observationCount(mrn: int): int {
    var count = 0
    place chart = ^charts[mrn]
    for seq in chart.observations at most 1000 {
        count += 1
    } on more return -1
    return count
}

// Write a diagnosis code through the wrapper-record constructor. A keyed scalar
// leaf would be a bare `^charts[mrn].diagnoses[pos] = code`; the wrapper forces the
// qualified `Chart.diagnoses(code: code)` constructor.
pub fn addDiagnosis(mrn: int, pos: int, code: string) {
    transaction {
        ^charts[mrn].diagnoses[pos] = Chart.diagnoses(code: code)
    }
}

// Count the recorded diagnosis codes under one chart. A keyed scalar leaf would
// read each code directly; the wrapper forces materializing each entry to reach
// its one `code` field.
pub fn diagnosisCount(mrn: int): int {
    var count = 0
    place chart = ^charts[mrn]
    for pos in chart.diagnoses at most 1000 {
        count += 1
    } on more return -1
    return count
}
