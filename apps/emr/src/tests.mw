module tests

use model

// Source tests for the EMR change-set tool. Each test drives the public exports
// only (driver mode) against its own fresh ephemeral store, so no test seeds
// durable data directly. Run with `marrow test`.

fn bundle0(): List<Change> {
    return List()
}

// example: an ordinary heterogeneous bundle commits every effect atomically.
test "apply: patient, encounter, observation in one bundle" {
    changeset::initStore()
    var b: List<Change> = List()
    b = append(b, Change::createPatient(id: 1, status: "active", display: "Ada Lovelace"))
    b = append(b, Change::createEncounter(id: 10, patientId: 1, status: "planned", reason: "A00"))
    b = append(b, Change::createObservation(id: 100, patientId: 1, encounterId: 10, status: "final", code: "GLUCOSE", value: 95))
    match changeset::applyChangeSet(b) {
        ok(applied) => {
            assert applied.explicitMutations == 3
            assert applied.implicitMutations == 0
            assert applied.touchedPatients == 1
            assert applied.firstAuditId == 1
        }
        err(e) => assert false
    }
    assert chart::patientExists(1)
    assert chart::patientRevision(1) == 1
    assert chart::aggregateRevision(1) == 1
    assert chart::countEncounters(1) == 1
    assert chart::countObservations(1) == 1
    assert chart::countEncounterObservations(10) == 1
    assert chart::countAllAudits(1) == 3
    assert chart::nextAuditId() == 4
}

// example: entry order does not change the committed state — an observation may
// reference an encounter created later in the same bundle.
test "apply: reference satisfied by a same-bundle create, any order" {
    changeset::initStore()
    var b: List<Change> = List()
    b = append(b, Change::createObservation(id: 100, patientId: 1, encounterId: 10, status: "preliminary", code: "HR", value: 70))
    b = append(b, Change::createEncounter(id: 10, patientId: 1, status: "in_progress", reason: "Z00"))
    b = append(b, Change::createPatient(id: 1, status: "active", display: "Grace Hopper"))
    match changeset::applyChangeSet(b) {
        ok(applied) => assert applied.explicitMutations == 3
        err(e) => assert false
    }
    assert chart::countObservations(1) == 1
    assert chart::countEncounters(1) == 1
}

// example: an update advances the revision and the patient aggregate.
test "apply: update advances revision and aggregate" {
    changeset::initStore()
    var b1: List<Change> = List()
    b1 = append(b1, Change::createPatient(id: 1, status: "active", display: "Ada"))
    match changeset::applyChangeSet(b1) {
        ok(a) => {}
        err(e) => assert false
    }
    assert chart::patientRevision(1) == 1
    assert chart::aggregateRevision(1) == 1
    var b2: List<Change> = List()
    b2 = append(b2, Change::updatePatient(id: 1, expectedRevision: 1, status: "inactive", display: "Ada L"))
    match changeset::applyChangeSet(b2) {
        ok(a) => {}
        err(e) => assert false
    }
    assert chart::patientRevision(1) == 2
    assert chart::aggregateRevision(1) == 2
    assert chart::patientStatus(1) == "inactive"
}

// example: a duplicate subject in one bundle is rejected and nothing commits.
test "reject: duplicate subject" {
    changeset::initStore()
    var b: List<Change> = List()
    b = append(b, Change::createPatient(id: 1, status: "active", display: "A"))
    b = append(b, Change::createPatient(id: 1, status: "inactive", display: "B"))
    match changeset::applyChangeSet(b) {
        ok(a) => assert false
        err(e) => assert changeset::rejectionCode(e) == "duplicateSubject"
    }
    assert not chart::patientExists(1)
}

// example: a stale expected revision is rejected.
test "reject: stale revision" {
    changeset::initStore()
    var b1: List<Change> = List()
    b1 = append(b1, Change::createPatient(id: 1, status: "active", display: "A"))
    match changeset::applyChangeSet(b1) {
        ok(a) => {}
        err(e) => assert false
    }
    var b2: List<Change> = List()
    b2 = append(b2, Change::updatePatient(id: 1, expectedRevision: 5, status: "inactive", display: "A"))
    match changeset::applyChangeSet(b2) {
        ok(a) => assert false
        err(e) => assert changeset::rejectionCode(e) == "staleRevision"
    }
    assert chart::patientRevision(1) == 1
}

// example: a missing patient reference is rejected and the bundle rolls back
// whole — the valid patient in the same bundle is not committed.
test "reject: missing reference is atomic" {
    changeset::initStore()
    var b: List<Change> = List()
    b = append(b, Change::createPatient(id: 1, status: "active", display: "A"))
    b = append(b, Change::createEncounter(id: 10, patientId: 999, status: "planned", reason: "A00"))
    match changeset::applyChangeSet(b) {
        ok(a) => assert false
        err(e) => assert changeset::rejectionCode(e) == "patientMissing"
    }
    assert not chart::patientExists(1)
    assert chart::countEncounters(1) == 0
}

// example: a new active medication supersedes the incumbent at the same
// (patient, code), producing one implicit supersession mutation.
test "apply: active medication supersession" {
    changeset::initStore()
    var b1: List<Change> = List()
    b1 = append(b1, Change::createPatient(id: 1, status: "active", display: "A"))
    b1 = append(b1, Change::createMedicationOrder(id: 50, patientId: 1, code: "RX", status: "active", dose: 10))
    match changeset::applyChangeSet(b1) {
        ok(a) => assert a.explicitMutations == 2
        err(e) => assert false
    }
    assert chart::activeMedicationOrder(1, "RX") == 50
    assert chart::countActiveMedications(1) == 1

    var b2: List<Change> = List()
    b2 = append(b2, Change::createMedicationOrder(id: 51, patientId: 1, code: "RX", status: "active", dose: 20))
    match changeset::applyChangeSet(b2) {
        ok(a) => {
            assert a.explicitMutations == 1
            assert a.implicitMutations == 1
        }
        err(e) => assert false
    }
    assert chart::activeMedicationOrder(1, "RX") == 51
    assert chart::countActiveMedications(1) == 1
}

// example: two active creates for the same (patient, code) in one bundle collide.
test "reject: active medication collision" {
    changeset::initStore()
    var b: List<Change> = List()
    b = append(b, Change::createPatient(id: 1, status: "active", display: "A"))
    b = append(b, Change::createMedicationOrder(id: 50, patientId: 1, code: "RX", status: "active", dose: 10))
    b = append(b, Change::createMedicationOrder(id: 51, patientId: 1, code: "RX", status: "active", dose: 20))
    match changeset::applyChangeSet(b) {
        ok(a) => assert false
        err(e) => assert changeset::rejectionCode(e) == "activeMedicationCollision"
    }
    assert not chart::patientExists(1)
}

// example: an empty bundle is rejected.
test "reject: empty bundle" {
    changeset::initStore()
    match changeset::applyChangeSet(bundle0()) {
        ok(a) => assert false
        err(e) => assert changeset::rejectionCode(e) == "emptyBundle"
    }
}

// example: paging a patient's audit history in ascending order, page size 2.
test "read: audit history pages by two" {
    changeset::initStore()
    var b: List<Change> = List()
    b = append(b, Change::createPatient(id: 1, status: "active", display: "A"))
    b = append(b, Change::createEncounter(id: 10, patientId: 1, status: "planned", reason: "A00"))
    b = append(b, Change::createEncounter(id: 11, patientId: 1, status: "planned", reason: "A01"))
    match changeset::applyChangeSet(b) {
        ok(a) => {}
        err(e) => assert false
    }
    // three audit links for patient 1 (one per mutation) at audit IDs 1,2,3: a
    // full first page {1,2}, then the next page from 3 (last seen + 1) is {3}.
    assert chart::countAllAudits(1) == 3
    assert chart::countAuditPage(1, 0) == 2
    assert chart::countAuditPage(1, 3) == 1
}
