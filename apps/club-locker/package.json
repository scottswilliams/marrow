{
  "name": "club-locker",
  "version": "0.1.0",
  "private": true,
  "description": "A minimal Club Locker desktop app over a local Marrow store, via the generated strict TypeScript client and the trusted Electron main.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "out/app/main.mjs",
  "scripts": {
    "typecheck": "tsc --noEmit -p .",
    "build": "tsc -p . && node tools/stage.mjs",
    "verify-deployment": "node gate/verify-deployment.mjs",
    "probe": "node gate/probe.mjs",
    "setup": "node tools/setup.mjs",
    "start": "electron ."
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "electron": "33.3.1",
    "typescript": "5.9.3"
  }
}
