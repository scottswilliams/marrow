module optional

pub fn orDefaultAbsent(): int {
    const x: int? = absent
    return x ?? 5
}

pub fn orDefaultPresent(): int {
    const x: int? = 7
    return x ?? 5
}

pub fn ifConstPresent(): int {
    const x: int? = 7
    if const v = x {
        return v
    }
    return 0
}

pub fn ifConstAbsent(): int {
    const x: int? = absent
    if const v = x {
        return v
    }
    return 0
}
