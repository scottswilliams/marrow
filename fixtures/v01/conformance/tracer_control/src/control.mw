module control

pub fn sumTo(n: int): int {
    var s = 0
    var i = 1
    while i <= n {
        s = s + i
        i = i + 1
    }
    return s
}

pub fn firstEvenOver(n: int): int {
    var i = 0
    while true {
        i = i + 1
        if i <= n { continue }
        if i % 2 != 0 { continue }
        break
    }
    return i
}

pub fn sign(a: int): int {
    if a > 0 {
        return 1
    } else if a == 0 {
        return 0
    } else return -1
}
