module structs

alias Name = string

struct Point
    x: int
    y: int

struct Person
    name: Name
    age: int
    active: bool

; A struct is a value: construct it, bind it, read its fields.

pub fn pointX(a: int, b: int): int
    const p = Point(x: a, y: b)
    return p.x

pub fn pointY(a: int, b: int): int
    const p = Point(x: a, y: b)
    return p.y

pub fn sum(a: int, b: int): int
    const p = Point(x: a, y: b)
    return p.x + p.y

pub fn personAge(n: string, a: int): int
    const person = Person(name: n, age: a, active: true)
    return person.age

pub fn personActive(a: int): bool
    const person = Person(name: "x", age: a, active: a > 0)
    return person.active

; A struct value is admitted as a parameter and a return type: it travels by
; value into and out of ordinary functions, beside scalar parameters.

pub fn shift(p: Point, dx: int, dy: int): Point
    return Point(x: p.x + dx, y: p.y + dy)

pub fn makePoint(a: int, b: int): Point
    return Point(x: a, y: b)

pub fn translateX(start: int, dx: int): int
    const p = Point(x: start, y: 0)
    const moved = shift(p, dx, 0)
    return moved.x
