module structs

alias Name = string

struct Point
    x: int
    y: int

struct Person
    name: Name
    age: int
    active: bool

; A struct is a value: construct it, bind it, read its fields.

pub fn pointX(a: int, b: int): int
    const p = Point(x: a, y: b)
    return p.x

pub fn pointY(a: int, b: int): int
    const p = Point(x: a, y: b)
    return p.y

pub fn sum(a: int, b: int): int
    const p = Point(x: a, y: b)
    return p.x + p.y

pub fn personAge(n: string, a: int): int
    const person = Person(name: n, age: a, active: true)
    return person.age

pub fn personActive(a: int): bool
    const person = Person(name: "x", age: a, active: a > 0)
    return person.active

; A struct value is admitted as a parameter and a return type: it travels by
; value into and out of ordinary functions, beside scalar parameters.

pub fn shift(p: Point, dx: int, dy: int): Point
    return Point(x: p.x + dx, y: p.y + dy)

pub fn makePoint(a: int, b: int): Point
    return Point(x: a, y: b)

pub fn translateX(start: int, dx: int): int
    const p = Point(x: start, y: 0)
    const moved = shift(p, dx, 0)
    return moved.x

; A struct field may itself be a struct (nesting behind the acyclicity proof), a
; struct declared later in the file (a forward reference), or a user enum. There
; is no depth restriction other than that the value graph has no cycle.

enum Tint
    plain
    bright

struct Segment
    a: Point
    b: Point

struct Tagged
    where: Segment
    tint: Tint

pub fn segmentBX(a: int, b: int, c: int, d: int): int
    const s = Segment(a: Point(x: a, y: b), b: Point(x: c, y: d))
    return s.b.x

pub fn makeTagged(): Tagged
    return Tagged(where: Segment(a: Point(x: 1, y: 2), b: Point(x: 3, y: 4)), tint: Tint::bright)

pub fn tintName(t: Tagged): string
    match t.tint
        plain
            return "plain"
        bright
            return "bright"

; A forward reference: `Wrap` names `Leaf`, declared afterwards.

struct Wrap
    leaf: Leaf

struct Leaf
    v: int

pub fn wrapValue(v: int): int
    const w = Wrap(leaf: Leaf(v: v))
    return w.leaf.v

; Nested equality routes through the VM's structural `EqEnum`: two `some(Point)`
; values are equal exactly when their payload structs are field-wise equal.

pub fn sameBoxedPoint(a: int, b: int, c: int, d: int): bool
    const p = some(Point(x: a, y: b))
    const q = some(Point(x: c, y: d))
    return p == q
