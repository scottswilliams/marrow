module collections

struct Point {
    x: int
    y: int
}

enum Color {
    red
    green
}

test "an empty list has length zero and is empty" {
    const xs: List<int> = List()
    assert length(xs) == 0
    assert isEmpty(xs)
}

test "append grows a list and iteration sums its elements" {
    var xs: List<int> = List()
    xs = append(xs, 10)
    xs = append(xs, 20)
    xs = append(xs, 12)
    assert length(xs) == 3
    assert not isEmpty(xs)
    var total: int = 0
    for x in xs {
        total += x
    }
    assert total == 42
}

test "list iteration preserves insertion order" {
    var xs: List<string> = List()
    xs = append(xs, "a")
    xs = append(xs, "b")
    xs = append(xs, "c")
    var joined: string = ""
    for s in xs {
        joined += s
    }
    assert joined == "abc"
}

test "a list holds struct values" {
    var pts: List<Point> = List()
    pts = append(pts, Point(x: 1, y: 2))
    pts = append(pts, Point(x: 3, y: 4))
    var sum: int = 0
    for p in pts {
        sum = sum + p.x + p.y
    }
    assert sum == 10
}

test "list positions are 1-based: first and last element identities" {
    var xs: List<string> = List()
    xs = append(xs, "a")
    xs = append(xs, "b")
    xs = append(xs, "c")
    assert xs[1] ?? "" == "a"
    assert xs[length(xs)] ?? "" == "c"
}

test "a computed out-of-range list index reads absent" {
    var xs: List<int> = List()
    xs = append(xs, 10)
    xs = append(xs, 20)
    var zero: int = 0
    if const miss = xs[zero] {
        assert false
    } else {
        assert true
    }
    const past = length(xs) + 1
    if const missPast = xs[past] {
        assert false
    } else {
        assert true
    }
}

test "every position in 1..=length reads a present element" {
    var xs: List<int> = List()
    xs = append(xs, 5)
    xs = append(xs, 7)
    xs = append(xs, 9)
    var sum: int = 0
    var seen: int = 0
    for i in 1..=length(xs) {
        if const e = xs[i] {
            sum += e
            seen += 1
        }
    }
    assert seen == length(xs)
    assert sum == 21
}

test "an empty map has length zero and a missing key reads absent" {
    const m: Map<string, int> = Map()
    assert length(m) == 0
    assert isEmpty(m)
    if const hit = m["missing"] {
        assert false
    } else {
        assert true
    }
}

test "a bracket assignment then lookup returns the stored value" {
    var m: Map<string, int> = Map()
    m["ada"] = 10
    m["grace"] = 12
    assert length(m) == 2
    const hit = m["grace"] ?? 0
    assert hit == 12
}

test "a bracket assignment replaces the value at an existing key" {
    var m: Map<string, int> = Map()
    m["k"] = 1
    m["k"] = 9
    assert length(m) == 1
    assert m["k"] ?? 0 == 9
}

test "a Map<int, V> admits the key zero" {
    var m: Map<int, int> = Map()
    m[0] = 100
    assert m[0] ?? -1 == 100
}

test "a copied map does not alias its source" {
    var a: Map<string, int> = Map()
    a["k"] = 1
    var b = a
    b["k"] = 9
    assert a["k"] ?? 0 == 1
    assert b["k"] ?? 0 == 9
}

test "durable positions round-trip through a hole-preserving Map<int, string>" {
    var byPos: Map<int, string> = Map()
    byPos[1] = "ada"
    byPos[3] = "grace"
    assert byPos[1] ?? "" == "ada"
    assert byPos[3] ?? "" == "grace"
    if const hole = byPos[2] {
        assert false
    } else {
        assert true
    }
    assert length(byPos) == 2
}

test "map iteration visits keys in ascending order" {
    var m: Map<int, int> = Map()
    m[3] = 30
    m[1] = 10
    m[2] = 20
    var keyOrder: int = 0
    var valueSum: int = 0
    for k, v in m {
        keyOrder = keyOrder * 10 + k
        valueSum += v
    }
    assert keyOrder == 123
    assert valueSum == 60
}

test "map key-only iteration binds keys in order" {
    var m: Map<int, string> = Map()
    m[2] = "b"
    m[1] = "a"
    var sum: int = 0
    for k in m {
        sum += k
    }
    assert sum == 3
}

test "a map value may itself be a list" {
    var m: Map<string, List<int>> = Map()
    var xs: List<int> = List()
    xs = append(xs, 5)
    xs = append(xs, 6)
    m["row"] = xs
    if const row = m["row"] {
        assert length(row) == 2
    } else {
        assert false
    }
}

test "split divides a string into a list of substrings" {
    const parts = split("a,b,c", ",")
    assert length(parts) == 3
    assert join(parts, "|") == "a|b|c"
    // An empty separator yields the whole string as one element.
    const whole = split("abc", "")
    assert length(whole) == 1
    assert join(whole, "|") == "abc"
}

test "lines splits a string on line feeds" {
    const ls = lines("one\ntwo\nthree")
    assert length(ls) == 3
    assert join(ls, "|") == "one|two|three"
    // A trailing line feed does not add an empty final line.
    const trailing = lines("a\nb\n")
    assert length(trailing) == 2
    assert join(trailing, "|") == "a|b"
}

test "join concatenates a list of string with a separator" {
    var xs: List<string> = List()
    xs = append(xs, "a")
    xs = append(xs, "b")
    xs = append(xs, "c")
    assert join(xs, "-") == "a-b-c"
    // Joining the empty list is the empty string.
    const empty: List<string> = List()
    assert join(empty, ",") == ""
}

test "split then join round-trips through the separator" {
    assert join(split("x:y:z", ":"), ":") == "x:y:z"
}

// A runtime export driven by `marrow run` to exercise the law-9 aggregate-byte
// bound: appending a 64 KiB string enough times pushes the list past the 1 MiB
// aggregate limit and faults `run.collection_limit`.
pub fn overflowAggregate(): int {
    var big: string = "x"
    var doublings: int = 0
    while doublings < 16 {
        big += big
        doublings += 1
    }
    var xs: List<string> = List()
    var appended: int = 0
    while appended < 32 {
        xs = append(xs, big)
        appended += 1
    }
    return length(xs)
}

// A runtime export driven by `marrow run` to exercise the `run.text_limit` ceiling
// on `join`: a list within the collection bounds whose joined text exceeds the 64 KiB
// concatenation ceiling faults rather than materializing an unbounded string.
pub fn overflowJoin(): int {
    var big: string = "x"
    var doublings: int = 0
    while doublings < 13 {
        big += big
        doublings += 1
    }
    var xs: List<string> = List()
    var appended: int = 0
    while appended < 16 {
        xs = append(xs, big)
        appended += 1
    }
    const whole = join(xs, "")
    if isEmpty(whole) { return 0 }
    return 1
}

test "a list of enum values iterates by value" {
    var cs: List<Color> = List()
    cs = append(cs, Color::red)
    cs = append(cs, Color::green)
    cs = append(cs, Color::red)
    var reds: int = 0
    for c in cs {
        match c {
            red => reds += 1
            green => reds += 0
        }
    }
    assert reds == 2
}
